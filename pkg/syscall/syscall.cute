build os("linux")

fn Syscall(trap: u64, a1: u64, a2: u64, a3: u64) u64 {
    build asm {
        mov EAX, $trap
        mov EBX, $a1
        mov ECX, $a2
        mov EDX, $a3
        int 0x80
    }
    ret 0
}

fn Syscall6(trap: u64, a1: u64, a2: u64, a3: u64, a4: u64, a5: u64, a6: u64) u64 {
    build asm {
        mov EAX, $trap
        mov EBX, $a1
        mov ECX, $a2
        mov EDX, $a3
        mov ESI, $a4
        mov EDI, $a5
        mov EBP, $a6
        int 0x80
    }
    ret 0
}