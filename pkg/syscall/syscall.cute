build os("linux")

fn syscall(trap: u32, a1: u32, a2: u32, a3: u32) u32 {
    build asm {
        mov EAX, $trap
        mov EBX, $a1
        mov ECX, $a2
        mov EDX, $a3
        int 0x80
    }
    ret 0
}

fn syscall6(trap: u32, a1: u32, a2: u32, a3: u32, a4: u32, a5: u32, a6: u32) u32 {
    build asm {
        mov EAX, $trap
        mov EBX, $a1
        mov ECX, $a2
        mov EDX, $a3
        mov ESI, $a4
        mov EDI, $a5
        mov EBP, $a6
        int 0x80
    }
    ret 0
}