// 测试结构体功能
struct Person {
    name: string
    age: int
    pub height: int
}

// 测试结构体继承
struct Student : Person {
    studentId: string
    grade: int
}

fn main() {
    var p: Person
    p.name = "Alice"
    p.age = 30
    p.height = 170
    
    var s: Student
    s.name = "Bob"
    s.studentId = "12345"
    s.grade = 10
}