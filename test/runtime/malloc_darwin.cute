build os "darwin"

fn mmap(addr: u64, length: u64, prot: i32, flags: i32, fd: i32, offset: u64) u64 {
    build extern("mmap")
}

fn munmap(addr: u64, length: u64) i32 {
    build extern("munmap")
}

fn malloc(size: u64) u64 {
    ret mmap(0, size, 3, 34, -1, 0)
}

fn free(ptr: u64) i32 {
    if (ptr == 0) {
        ret 0
    }
    ret munmap(ptr, 0)
}
