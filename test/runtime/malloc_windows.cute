build os "windows"

fn VirtualAlloc(lpAddress: u64, dwSize: u64, flAllocationType: u64, flProtect: u64) u64 {
    build extern("VirtualAlloc")
}

fn VirtualFree(lpAddress: u64, dwSize: u64, dwFreeType: u64) i32 {
    build extern("VirtualFree")
}

fn malloc(size: u64) u64 {
    ret VirtualAlloc(0, size, 12288, 4)
}

fn free(ptr: u64) i32 {
    if (ptr == 0) {
        ret 0
    }
    ret VirtualFree(ptr, 0, 32768)
}
